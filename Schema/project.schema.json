{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sysforge.local/schema/project.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "ownerId",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique project identifier."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "ownerId": {
      "type": "string",
      "description": "ID of the user who owns the project."
    },
    "status": {
      "type": "string",
      "enum": [
        "planning",
        "active",
        "paused",
        "completed"
      ],
      "default": "planning"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
